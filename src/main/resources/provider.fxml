<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" styleClass="tab-content" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" stylesheets="@styles.css" fx:controller="Application.ProviderControllerFXML">
   <padding><Insets bottom="20" left="24" right="24" top="20"/></padding>
   <Label text="%admin.provider.title" styleClass="form-title"/>
   <HBox spacing="12" alignment="CENTER_LEFT">
      <Label text="%admin.provider.search" styleClass="field-label"/>
      <TextField fx:id="searchField" promptText="%admin.provider.searchPrompt" styleClass="text-input" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
      <ComboBox fx:id="searchTypeCombo" prefWidth="140"/>
      <Button onAction="#handleSearch" text="%common.search" styleClass="btn-secondary"/>
   </HBox>
   <VBox styleClass="form-container" spacing="16">
      <GridPane hgap="18" vgap="14">
         <columnConstraints><ColumnConstraints minWidth="120" prefWidth="120"/><ColumnConstraints minWidth="250" prefWidth="300"/></columnConstraints>
         <Label text="%common.id" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
         <TextField fx:id="idField" editable="false" styleClass="text-input" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
         <Label text="%common.name" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
         <TextField fx:id="nameField" styleClass="text-input" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
         <Label text="%admin.provider.phone" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
         <TextField fx:id="phoneField" styleClass="text-input" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
         <Label text="%admin.provider.email" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
         <TextField fx:id="emailField" styleClass="text-input" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
         <Label text="%admin.provider.address" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
         <TextField fx:id="addressField" styleClass="text-input" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
      </GridPane>
      <HBox styleClass="form-actions" spacing="12">
         <Button fx:id="addButton" onAction="#handleAdd" text="%common.add" styleClass="btn-success"/>
         <Button fx:id="updateButton" onAction="#handleUpdate" text="%common.update" styleClass="btn-warning"/>
         <Button fx:id="deleteButton" onAction="#handleDelete" text="%common.delete" styleClass="btn-danger"/>
         <Button fx:id="refreshButton" onAction="#handleRefresh" text="%common.refresh" styleClass="btn-secondary"/>
      </HBox>
      <Label fx:id="messageLabel" text=""/>
   </VBox>
   <TableView fx:id="tableView" styleClass="table-view" VBox.vgrow="ALWAYS">
      <columns>
         <TableColumn fx:id="idCol" prefWidth="60" text="%common.id"/>
         <TableColumn fx:id="nameCol" prefWidth="150" text="%common.name"/>
         <TableColumn fx:id="phoneCol" prefWidth="120" text="%admin.provider.phone"/>
         <TableColumn fx:id="emailCol" prefWidth="180" text="%admin.provider.email"/>
         <TableColumn fx:id="addressCol" prefWidth="250" text="%admin.provider.address"/>
      </columns>
   </TableView>
</VBox>
