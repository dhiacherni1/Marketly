<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" styleClass="tab-content" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" stylesheets="@styles.css" fx:controller="Application.UserControllerFXML">
   <padding><Insets bottom="20" left="24" right="24" top="20"/></padding>
   <Label text="%admin.user.title" styleClass="form-title"/>
   <VBox styleClass="form-container" spacing="16">
      <GridPane hgap="18" vgap="14">
         <columnConstraints><ColumnConstraints minWidth="120" prefWidth="120"/><ColumnConstraints minWidth="250" prefWidth="300"/></columnConstraints>
         <Label text="%common.id" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
         <TextField fx:id="idField" editable="false" styleClass="text-input" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
         <Label text="%admin.user.username" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
         <TextField fx:id="usernameField" styleClass="text-input" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
         <Label text="%admin.user.password" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
         <PasswordField fx:id="passwordField" styleClass="text-input" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
         <Label text="%admin.user.role" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
         <ComboBox fx:id="roleCombo" styleClass="combo-box" prefWidth="150" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
      </GridPane>
      <HBox styleClass="form-actions" spacing="12">
         <Button fx:id="addButton" onAction="#handleAdd" text="%common.add" styleClass="btn-success"/>
         <Button fx:id="updateButton" onAction="#handleUpdate" text="%common.update" styleClass="btn-warning"/>
         <Button fx:id="deleteButton" onAction="#handleDelete" text="%common.delete" styleClass="btn-danger"/>
         <Button fx:id="refreshButton" onAction="#handleRefresh" text="%common.refresh" styleClass="btn-secondary"/>
      </HBox>
      <Label fx:id="messageLabel" text=""/>
   </VBox>
   <TableView fx:id="tableView" styleClass="table-view" VBox.vgrow="ALWAYS">
      <columns>
         <TableColumn fx:id="idCol" prefWidth="80" text="%common.id"/>
         <TableColumn fx:id="usernameCol" prefWidth="200" text="%admin.user.username"/>
         <TableColumn fx:id="passwordCol" prefWidth="150" text="%admin.user.password"/>
         <TableColumn fx:id="roleCol" prefWidth="150" text="%admin.user.role"/>
      </columns>
   </TableView>
</VBox>
